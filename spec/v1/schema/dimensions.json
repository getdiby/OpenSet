{
  "$comment": "OpenSet v1.0 — Canonical dimension vocabulary",
  "dimensions": {
    "reps": {
      "allowedTypes": ["fixed", "range", "min", "amrap"]
    },
    "sides": {
      "allowedTypes": ["fixed"]
    },
    "rounds": {
      "allowedTypes": ["fixed", "amrap"]
    },
    "load": {
      "allowedUnits": ["kg", "lb", "%1RM", "%BW"],
      "allowedTypes": ["fixed", "range", "max"]
    },
    "duration": {
      "unit": "s",
      "allowedUnits": ["s", "min", "h"],
      "allowedTypes": ["fixed", "range", "min"]
    },
    "duration_per_side": {
      "unit": "s",
      "allowedUnits": ["s", "min", "h"],
      "allowedTypes": ["fixed", "range"]
    },
    "rest_between_sides": {
      "unit": "s",
      "allowedUnits": ["s", "min", "h"],
      "allowedTypes": ["fixed"]
    },
    "rest_after": {
      "unit": "s",
      "allowedUnits": ["s", "min", "h"],
      "allowedTypes": ["fixed", "range"],
      "precedence": "SET overrides SERIES"
    },
    "tempo": {
      "description": "e.g. 3-1-1-0",
      "allowedTypes": ["fixed"]
    },
    "distance": {
      "allowedUnits": ["m", "km", "mi", "ft", "yd"],
      "allowedTypes": ["fixed", "range", "min", "amrap"]
    },
    "height": {
      "unit": "cm",
      "allowedUnits": ["cm", "in"],
      "allowedTypes": ["fixed", "range"]
    },
    "incline": {
      "description": "Gradient as percentage (%) — treadmill, outdoor running, cycling",
      "unit": "%",
      "allowedUnits": ["%"],
      "allowedTypes": ["fixed", "range"]
    },
    "pace": {
      "allowedUnits": ["min/km", "min/mi"],
      "allowedTypes": ["fixed", "range"]
    },
    "speed": {
      "allowedUnits": ["km/h", "mph"],
      "allowedTypes": ["fixed", "range"]
    },
    "power": {
      "description": "Absolute watts (W) or relative to athlete FTP (%FTP). Use %FTP for portable cycling/ERG workouts.",
      "unit": "W",
      "allowedUnits": ["W", "%FTP"],
      "allowedTypes": ["fixed", "range"]
    },
    "heart_rate": {
      "unit": "bpm",
      "allowedUnits": ["bpm", "%HRR", "%HRmax"],
      "allowedTypes": ["fixed", "range", "max"]
    },
    "heart_rate_zone": {
      "description": "1–5",
      "allowedTypes": ["fixed", "range"]
    },
    "rpe": {
      "description": "1–10",
      "allowedTypes": ["fixed", "range", "max"]
    },
    "rir": {
      "description": "Reps in reserve at end of set (0–5 recommended)",
      "allowedTypes": ["fixed", "range", "max"]
    },
    "velocity": {
      "description": "Barbell/implement velocity (m/s) — for velocity-based training",
      "allowedUnits": ["m/s"],
      "allowedTypes": ["fixed", "range"]
    },
    "calories": {
      "allowedUnits": ["kcal"],
      "allowedTypes": ["fixed", "min", "amrap"]
    },
    "cadence": {
      "description": "Repetition rate — rpm, spm, strokes/min",
      "allowedUnits": ["rpm", "spm"],
      "allowedTypes": ["fixed", "range"]
    },
    "resistance": {
      "description": "Machine resistance level or percentage",
      "allowedUnits": ["level", "%"],
      "allowedTypes": ["fixed", "range"]
    }
  },
  "dimension_conflicts": [
    ["pace", "speed"],
    ["heart_rate", "heart_rate_zone"]
  ]
}
