{
  "$comment": "OpenSet v1.0 — Canonical value type vocabulary",
  "valueTypes": {
    "fixed": {
      "description": "Exact prescribed target",
      "requiredFields": ["value", "unit"],
      "example": { "type": "fixed", "value": 100, "unit": "kg" }
    },
    "range": {
      "description": "Work within bounds, inclusive",
      "requiredFields": ["min", "max", "unit"],
      "example": { "type": "range", "min": 8, "max": 12 }
    },
    "min": {
      "description": "At least this value, no upper cap",
      "requiredFields": ["value", "unit"],
      "example": { "type": "min", "value": 30, "unit": "s" }
    },
    "amrap": {
      "description": "As many / as much as possible",
      "requiredFields": [],
      "example": { "type": "amrap" }
    },
    "max": {
      "description": "Single maximum effort (e.g. 1RM)",
      "requiredFields": [],
      "example": { "type": "max" }
    },
    "any": {
      "description": "No target, free / unstructured",
      "requiredFields": [],
      "example": { "type": "any" }
    }
  },
  "units": {
    "weight": ["kg", "lb"],
    "relative_weight": ["%1RM", "%BW"],
    "distance": ["m", "km", "mi", "yards"],
    "time": ["s", "min", "hr"],
    "speed": ["km/h", "mph", "min/km", "min/mi"],
    "velocity": ["m/s"],
    "power": ["W"],
    "height": ["cm", "in"],
    "heart_rate": ["bpm"],
    "unitless": null
  }
}
