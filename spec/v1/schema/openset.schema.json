{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openset.dev/schema/v1/openset.schema.json",
  "title": "OpenSet Training Document",
  "description": "An open, sport-agnostic standard for representing structured training sessions and programs as machine-readable data.",

  "oneOf": [
    { "$ref": "#/$defs/StandaloneSession" },
    { "$ref": "#/$defs/ProgramDocument" }
  ],

  "$defs": {

    "StandaloneSession": {
      "type": "object",
      "required": ["openset_version", "type", "blocks"],
      "properties": {
        "openset_version": { "type": "string", "const": "1.0" },
        "type": { "type": "string", "const": "session" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "note": { "type": "string" },
        "library": { "$ref": "#/$defs/LibraryRef" },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Block" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "ProgramDocument": {
      "type": "object",
      "required": ["openset_version", "type", "name", "phases"],
      "properties": {
        "openset_version": { "type": "string", "const": "1.0" },
        "type": { "type": "string", "const": "program" },
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sport": { "type": "string" },
        "duration_weeks": { "type": "integer", "minimum": 1 },
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/Phase" },
          "minItems": 1
        },
        "created_at": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    },

    "Phase": {
      "type": "object",
      "required": ["name", "sessions"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "week_start": { "type": "integer", "minimum": 1 },
        "week_end": { "type": "integer", "minimum": 1 },
        "goal": { "type": "string" },
        "sessions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Session" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Session": {
      "type": "object",
      "required": ["blocks"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "note": { "type": "string" },
        "library": { "$ref": "#/$defs/LibraryRef" },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Block" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "LibraryRef": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },

    "Block": {
      "type": "object",
      "required": ["series"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "note": { "type": "string" },
        "series": {
          "type": "array",
          "items": { "$ref": "#/$defs/Series" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Series": {
      "type": "object",
      "required": ["execution_mode", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": [
            "SEQUENTIAL", "CIRCUIT", "SUPERSET",
            "AMRAP", "FOR_TIME", "INTERVAL",
            "TABATA", "EMOM", "LADDER", "CLUSTER"
          ]
        },
        "rounds": { "$ref": "#/$defs/ValueObject" },
        "rest_after": { "$ref": "#/$defs/ValueObject" },
        "note": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/$defs/Exercise" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Exercise": {
      "type": "object",
      "required": ["sets"],
      "oneOf": [
        { "required": ["exercise_id"] },
        { "required": ["name"] }
      ],
      "properties": {
        "exercise_id": { "type": "string" },
        "name": { "type": "string" },
        "group": { "type": "string" },
        "note": { "type": "string" },
        "sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/Set" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Set": {
      "type": "object",
      "required": ["execution_type"],
      "properties": {
        "execution_type": {
          "type": "string",
          "enum": [
            "reps_only", "reps_load", "reps_per_side", "reps_height",
            "duration_only", "duration_load", "duration_per_side", "duration_power",
            "distance_only", "distance_time", "distance_load",
            "power_duration", "power_distance",
            "calories_only", "distance_calories", "rounds_time"
          ]
        },
        "reps": { "$ref": "#/$defs/ValueObject" },
        "sides": { "$ref": "#/$defs/ValueObject" },
        "rounds": { "$ref": "#/$defs/ValueObject" },
        "load": { "$ref": "#/$defs/ValueObject" },
        "duration": { "$ref": "#/$defs/ValueObject" },
        "duration_per_side": { "$ref": "#/$defs/ValueObject" },
        "rest_between_sides": { "$ref": "#/$defs/ValueObject" },
        "rest_after": { "$ref": "#/$defs/ValueObject" },
        "tempo": { "$ref": "#/$defs/ValueObject" },
        "distance": { "$ref": "#/$defs/ValueObject" },
        "height": { "$ref": "#/$defs/ValueObject" },
        "incline": { "$ref": "#/$defs/ValueObject" },
        "pace": { "$ref": "#/$defs/ValueObject" },
        "speed": { "$ref": "#/$defs/ValueObject" },
        "power": { "$ref": "#/$defs/ValueObject" },
        "heart_rate": { "$ref": "#/$defs/ValueObject" },
        "heart_rate_zone": { "$ref": "#/$defs/ValueObject" },
        "rpe": { "$ref": "#/$defs/ValueObject" },
        "velocity": { "$ref": "#/$defs/ValueObject" },
        "calories": { "$ref": "#/$defs/ValueObject" },
        "note": { "type": "string" }
      },
      "patternProperties": {
        "^x_": { "description": "Generic extension dimension" },
        "^app_": { "description": "App-specific extension dimension" },
        "^[a-z]+_[a-z]+_": { "description": "Reverse-DNS extension dimension" }
      },
      "additionalProperties": false
    },

    "ValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedValue" },
        { "$ref": "#/$defs/RangeValue" },
        { "$ref": "#/$defs/MinValue" },
        { "$ref": "#/$defs/AmrapValue" },
        { "$ref": "#/$defs/MaxValue" },
        { "$ref": "#/$defs/AnyValue" }
      ]
    },

    "FixedValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "fixed" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "RangeValue": {
      "type": "object",
      "required": ["type", "min", "max"],
      "properties": {
        "type": { "type": "string", "const": "range" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "MinValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "min" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "AmrapValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "amrap" }
      },
      "additionalProperties": false
    },

    "MaxValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "max" }
      },
      "additionalProperties": false
    },

    "AnyValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "any" }
      },
      "additionalProperties": false
    }
  }
}
