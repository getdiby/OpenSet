{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openset.dev/schema/v1/workout-library.schema.json",
  "title": "OpenSet Workout Library",
  "description": "Schema for validating OpenSet workout library documents",
  "type": "object",
  "required": ["openset_version", "type", "id", "name", "version", "provider", "license", "workouts"],
  "properties": {
    "openset_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "workout_library" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "provider": { "type": "string" },
    "license": { "type": "string" },
    "workouts": {
      "type": "array",
      "items": { "$ref": "#/$defs/WorkoutDefinition" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "WorkoutDefinition": {
      "type": "object",
      "required": ["id", "name", "blocks"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(_[a-z0-9]+)*$",
          "description": "Unique snake_case identifier within the library"
        },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "elite"]
        },
        "duration": { "$ref": "#/$defs/DurationValue" },
        "sports": { "type": "array", "items": { "type": "string" } },
        "note": { "type": "string" },
        "library": { "$ref": "#/$defs/LibraryRef" },
        "media": { "$ref": "#/$defs/Media" },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Block" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "LibraryRef": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },

    "Media": {
      "type": "object",
      "properties": {
        "videos": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "label"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "label": { "type": "string" },
              "language": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "photos": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "label"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "label": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "Block": {
      "type": "object",
      "required": ["series"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "note": { "type": "string" },
        "series": {
          "type": "array",
          "items": { "$ref": "#/$defs/Series" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Series": {
      "type": "object",
      "required": ["execution_mode", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": [
            "SEQUENTIAL", "CIRCUIT", "SUPERSET",
            "AMRAP", "FOR_TIME", "INTERVAL",
            "TABATA", "EMOM", "LADDER", "CLUSTER"
          ]
        },
        "rounds": { "$ref": "#/$defs/RoundsValueObject" },
        "rest_after": { "$ref": "#/$defs/RestAfterValueObject" },
        "note": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/$defs/Exercise" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Exercise": {
      "type": "object",
      "required": ["sets"],
      "oneOf": [
        { "required": ["exercise_id"] },
        { "required": ["name"] }
      ],
      "properties": {
        "exercise_id": { "type": "string" },
        "name": { "type": "string" },
        "group": { "type": "string" },
        "note": { "type": "string" },
        "sets": {
          "type": "array",
          "items": { "$ref": "#/$defs/Set" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },

    "Set": {
      "type": "object",
      "required": ["dimensions"],
      "properties": {
        "dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reps", "sides", "rounds", "load", "duration",
              "duration_per_side", "rest_between_sides", "tempo",
              "distance", "height", "incline", "pace", "speed",
              "power", "heart_rate", "heart_rate_zone", "rpe",
              "velocity", "calories", "cadence", "resistance"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "reps": { "$ref": "#/$defs/RepsValueObject" },
        "sides": { "$ref": "#/$defs/SidesValueObject" },
        "rounds": { "$ref": "#/$defs/RoundsValueObject" },
        "load": { "$ref": "#/$defs/LoadValueObject" },
        "duration": { "$ref": "#/$defs/DurationValueObject" },
        "duration_per_side": { "$ref": "#/$defs/DurationPerSideValueObject" },
        "rest_between_sides": { "$ref": "#/$defs/RestBetweenSidesValueObject" },
        "rest_after": { "$ref": "#/$defs/RestAfterValueObject" },
        "tempo": { "$ref": "#/$defs/TempoValueObject" },
        "distance": { "$ref": "#/$defs/DistanceValueObject" },
        "height": { "$ref": "#/$defs/HeightValueObject" },
        "incline": { "$ref": "#/$defs/InclineValueObject" },
        "pace": { "$ref": "#/$defs/PaceValueObject" },
        "speed": { "$ref": "#/$defs/SpeedValueObject" },
        "power": { "$ref": "#/$defs/PowerValueObject" },
        "heart_rate": { "$ref": "#/$defs/HeartRateValueObject" },
        "heart_rate_zone": { "$ref": "#/$defs/HeartRateZoneValueObject" },
        "rpe": { "$ref": "#/$defs/RpeValueObject" },
        "velocity": { "$ref": "#/$defs/VelocityValueObject" },
        "calories": { "$ref": "#/$defs/CaloriesValueObject" },
        "cadence": { "$ref": "#/$defs/CadenceValueObject" },
        "resistance": { "$ref": "#/$defs/ResistanceValueObject" },
        "note": { "type": "string" }
      },
      "patternProperties": {
        "^x_": { "description": "Generic extension dimension" },
        "^app_": { "description": "App-specific extension dimension" },
        "^[a-z]+_[a-z]+_": { "description": "Reverse-DNS extension dimension" }
      },
      "additionalProperties": true
    },

    "DurationUnit": { "type": "string", "enum": ["s", "min", "h", "day", "week"] },

    "DurationValue": {
      "type": "object",
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "integer", "minimum": 1 },
        "unit": { "$ref": "#/$defs/DurationUnit" }
      },
      "additionalProperties": false
    },

    "LoadUnit": { "type": "string", "enum": ["kg", "lb", "%1RM", "%BW"] },
    "TimeUnit": { "type": "string", "enum": ["s", "min", "h"] },
    "DistanceUnit": { "type": "string", "enum": ["m", "km", "mi", "ft", "yd"] },
    "HeightUnit": { "type": "string", "enum": ["cm", "in"] },
    "InclineUnit": { "type": "string", "enum": ["%"] },
    "PaceUnit": { "type": "string", "enum": ["min/km", "min/mi"] },
    "SpeedUnit": { "type": "string", "enum": ["km/h", "mph"] },
    "PowerUnit": { "type": "string", "enum": ["W", "%FTP"] },
    "HeartRateUnit": { "type": "string", "enum": ["bpm"] },
    "VelocityUnit": { "type": "string", "enum": ["m/s"] },
    "CaloriesUnit": { "type": "string", "enum": ["kcal"] },
    "CadenceUnit": { "type": "string", "enum": ["rpm", "spm"] },
    "ResistanceUnit": { "type": "string", "enum": ["level", "%"] },

    "ValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedValue" },
        { "$ref": "#/$defs/RangeValue" },
        { "$ref": "#/$defs/MinValue" },
        { "$ref": "#/$defs/AmrapValue" },
        { "$ref": "#/$defs/MaxValue" },
        { "$ref": "#/$defs/AnyValue" }
      ]
    },

    "FixedValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "fixed" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "RangeValue": {
      "type": "object",
      "required": ["type", "min", "max"],
      "properties": {
        "type": { "type": "string", "const": "range" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "MinValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "min" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "FixedNoUnitValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "fixed" },
        "value": { "type": "number" }
      },
      "additionalProperties": false
    },

    "RangeNoUnitValue": {
      "type": "object",
      "required": ["type", "min", "max"],
      "properties": {
        "type": { "type": "string", "const": "range" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      },
      "additionalProperties": false
    },

    "MinNoUnitValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "const": "min" },
        "value": { "type": "number" }
      },
      "additionalProperties": false
    },

    "FixedWithUnitValue": {
      "type": "object",
      "required": ["type", "value", "unit"],
      "properties": {
        "type": { "type": "string", "const": "fixed" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "RangeWithUnitValue": {
      "type": "object",
      "required": ["type", "min", "max", "unit"],
      "properties": {
        "type": { "type": "string", "const": "range" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "MinWithUnitValue": {
      "type": "object",
      "required": ["type", "value", "unit"],
      "properties": {
        "type": { "type": "string", "const": "min" },
        "value": { "type": "number" },
        "unit": { "type": "string" }
      },
      "additionalProperties": false
    },

    "RepsValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" },
        { "$ref": "#/$defs/RangeNoUnitValue" },
        { "$ref": "#/$defs/MinNoUnitValue" },
        { "$ref": "#/$defs/AmrapValue" }
      ]
    },

    "SidesValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" }
      ]
    },

    "RoundsValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" },
        { "$ref": "#/$defs/AmrapValue" }
      ]
    },

    "LoadValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/LoadUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/LoadUnit" } } }
          ]
        },
        { "$ref": "#/$defs/MaxValue" }
      ]
    },

    "DurationValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/MinWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        }
      ]
    },

    "DurationPerSideValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        }
      ]
    },

    "RestBetweenSidesValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        }
      ]
    },

    "RestAfterValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/TimeUnit" } } }
          ]
        }
      ]
    },

    "TempoValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" }
      ]
    },

    "DistanceValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/DistanceUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/DistanceUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/MinWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/DistanceUnit" } } }
          ]
        },
        { "$ref": "#/$defs/AmrapValue" }
      ]
    },

    "HeightValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/HeightUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/HeightUnit" } } }
          ]
        }
      ]
    },

    "InclineValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/InclineUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/InclineUnit" } } }
          ]
        }
      ]
    },

    "PaceValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/PaceUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/PaceUnit" } } }
          ]
        }
      ]
    },

    "SpeedValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/SpeedUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/SpeedUnit" } } }
          ]
        }
      ]
    },

    "PowerValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/PowerUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/PowerUnit" } } }
          ]
        }
      ]
    },

    "HeartRateValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/HeartRateUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/HeartRateUnit" } } }
          ]
        },
        { "$ref": "#/$defs/MaxValue" }
      ]
    },

    "HeartRateZoneValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" },
        { "$ref": "#/$defs/RangeNoUnitValue" }
      ]
    },

    "RpeValueObject": {
      "oneOf": [
        { "$ref": "#/$defs/FixedNoUnitValue" },
        { "$ref": "#/$defs/RangeNoUnitValue" },
        { "$ref": "#/$defs/MaxValue" }
      ]
    },

    "VelocityValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/VelocityUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/VelocityUnit" } } }
          ]
        }
      ]
    },

    "CaloriesValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/CaloriesUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/MinWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/CaloriesUnit" } } }
          ]
        },
        { "$ref": "#/$defs/AmrapValue" }
      ]
    },

    "CadenceValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/CadenceUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/CadenceUnit" } } }
          ]
        }
      ]
    },

    "ResistanceValueObject": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/FixedWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/ResistanceUnit" } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/RangeWithUnitValue" },
            { "properties": { "unit": { "$ref": "#/$defs/ResistanceUnit" } } }
          ]
        }
      ]
    },

    "AmrapValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "amrap" }
      },
      "additionalProperties": false
    },

    "MaxValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "max" }
      },
      "additionalProperties": false
    },

    "AnyValue": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "any" }
      },
      "additionalProperties": false
    }
  }
}
