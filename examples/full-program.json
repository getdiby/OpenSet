{
  "openset_version": "1.0",
  "type": "program",
  "name": "4-Week Strength Foundation",
  "description": "A beginner-friendly 4-week program focusing on compound movements with progressive overload.",
  "sport": "strength",
  "duration_weeks": 4,
  "author": "OpenSet",
