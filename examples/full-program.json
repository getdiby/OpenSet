          "name": "Day 1 — Upper Body",
          "blocks": [
            {
              "name": "Main Work",
              "series": [
                {
                  "execution_mode": "SEQUENTIAL",
                  "exercises": [
                    {
                      "exercise_id": "bench_press",
                      "sets": [
                        { "execution_type": "reps_load", "reps": { "type": "fixed", "value": 8 }, "load": { "type": "fixed", "value": 60, "unit": "kg" }, "rpe": { "type": "fixed", "value": 7 }, "rest_after": { "type": "fixed", "value": 120, "unit": "s" } },
                        { "execution_type": "reps_load", "reps": { "type": "fixed", "value": 8 }, "load": { "type": "fixed", "value": 60, "unit": "kg" }, "rpe": { "type": "fixed", "value": 7 }, "rest_after": { "type": "fixed", "value": 120, "unit": "s" } },
