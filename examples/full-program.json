                      ]
                    },
                    {
                      "exercise_id": "seated_row",
                      "sets": [
                        { "execution_type": "reps_load", "reps": { "type": "fixed", "value": 10 }, "load": { "type": "fixed", "value": 50, "unit": "kg" }, "rest_after": { "type": "fixed", "value": 90, "unit": "s" } },
