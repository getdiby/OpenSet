                      ]
                    }
                  ]
                }
              ]
            },
            {
              "name": "Accessories",
              "series": [
                {
                  "execution_mode": "SUPERSET",
                  "rounds": { "type": "fixed", "value": 3 },
                  "rest_after": { "type": "fixed", "value": 60, "unit": "s" },
                  "exercises": [
                    {
                      "exercise_id": "triceps_cable_pushdown",
                      "sets": [
                        { "execution_type": "reps_load", "reps": { "type": "range", "min": 12, "max": 15 }, "load": { "type": "fixed", "value": 20, "unit": "kg" } },
                        { "execution_type": "reps_load", "reps": { "type": "range", "min": 12, "max": 15 }, "load": { "type": "fixed", "value": 20, "unit": "kg" } },
