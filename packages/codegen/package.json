{
  "name": "@openset/codegen",
  "version": "1.0.0",
  "description": "Fluent TypeScript builder for constructing valid OpenSet documents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@openset/types": "workspace:*"
  },
  "peerDependencies": {
    "@openset/validator": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@openset/validator": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openset/validator": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
